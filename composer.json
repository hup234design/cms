{
    "name": "hup234design/cms",
    "type": "project",
    "description": "CMS plugin for Filament Admin.",
    "keywords": [
        "framework",
        "laravel",
        "filament",
        "cms"
    ],
    "license": "MIT",
    "authors": [
        {
            "name": "Dave Walker",
            "email": "dave@hup234design.co.uk",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.1",
        "awcodes/filament-curator": "^2.6",
        "awcodes/filament-tiptap-editor": "^2.3",
        "camya/filament-title-with-slug": "^0.5.6",
        "filament/filament": "^2.0",
        "filipfonal/filament-log-manager": "^1.2",
        "laravel/pint": "^1.2",
        "pboivin/filament-peek": "dev-main",
        "ralphjsmit/laravel-filament-seo": "^1.0",
        "ryangjchandler/filament-navigation": "^0.5.0",
        "spatie/eloquent-sortable": "^4.0",
        "spatie/laravel-honeypot": "^4.3",
        "spatie/laravel-ray": "^1.32",
        "spatie/valuestore": "^1.3"
    },
    "autoload": {
        "psr-4": {
            "Hup234design\\Cms\\": "src/",
            "Hup234design\\Cms\\Database\\Seeders\\": "database/seeders/"
        },
        "files": [
            "src/helpers.php"
        ]
    },
    "extra": {
        "laravel": {
            "providers": [
                "Hup234design\\Cms\\CmsServiceProvider"
            ]
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    },
    "minimum-stability": "dev"
}
